APP_ENV=production
API_HOST=0.0.0.0
API_PORT=8000

# 线上前端地址，GitHub Pages 或自定义域名都写在这里
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://your-name.github.io"]

# 如果后端直接跑在服务器上，这里填服务器本机服务地址
SESSION_HISTORY_DB_URL=postgresql+psycopg://travel:travel@127.0.0.1:5432/travel_agent
FRONTEND_DIST_DIR=/root/rivermind-data/travel-agent/frontend-dist
ELASTICSEARCH_URL=http://127.0.0.1:9200

# 服务器上直接连中间件时保持关闭；如果仍然要走 SSH 隧道，再改成 true
JUSTONEAPI_ENABLED=false
JUSTONEAPI_KEY=
JUSTONEAPI_BASE_URL=https://api.justoneapi.com
JUSTONEAPI_CACHE_TTL_HOURS=168
JUSTONEAPI_MAX_NOTES_PER_PLAN=12
JUSTONEAPI_MAX_POIS_PER_PLAN=8

# DeepSeek 用于把笔记内容压成更干净的候选地点名
DEEPSEEK_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT=30
DEEPSEEK_MAX_NOTES_PER_REQUEST=8

REMOTE_MIDDLEWARE_SSH_ENABLED=false
REMOTE_MIDDLEWARE_AUTO_START=false
